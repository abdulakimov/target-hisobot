# ─────────────────────────────────────────────────────────────
# Hisobotchi — environment variables
# Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
TZ=Asia/Tashkent

# Public URLs (in dev these are your tunnel URL, e.g. https://xxx.trycloudflare.com)
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database (Postgres)
DATABASE_URL=postgresql://hisobotchi:change-me@localhost:5432/hisobotchi?schema=public
POSTGRES_USER=hisobotchi
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hisobotchi

# Telegram (grammY)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_POLLING_ENABLED=true

# Session — opaque Postgres session, cookie signing secret (>=32 chars)
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# Meta (Graph API)
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URL=http://localhost:3000/api/meta/callback
# AES-256-GCM key for encrypting Meta tokens at rest (>=32 chars)
META_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-string-min-32-chars
META_GRAPH_API_VERSION=v23.0
META_OAUTH_SCOPES=ads_read,business_management
