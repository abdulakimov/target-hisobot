{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    // NestJS is not yet NodeNext-native (extensionless imports); node10 resolution
    // is deprecated in TS6 but fully functional. Revisit when Nest ships NodeNext.
    "ignoreDeprecations": "6.0",
    "target": "ES2023",
    "lib": ["ES2023"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
